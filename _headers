# Cloudflare Pages headers — caching, security, performance

# All pages — security headers
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# HTML — short cache, must revalidate
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Long cache for static assets (CSS/JS won't change without a deploy)
/assets/css/*
  Cache-Control: public, max-age=604800, immutable

/assets/js/*
  Cache-Control: public, max-age=604800, immutable

# Images: long cache (filenames are content-addressable enough)
/assets/img/*
  Cache-Control: public, max-age=2592000, immutable

# Sitemap + robots: medium cache
/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600
