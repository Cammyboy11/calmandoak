# Calm & Oak — secrets template.
# Copy this file to ".env" (which is gitignored and never deployed) and fill in.
# Agents read these via process.env; they are never committed or served.

# --- #3 Email: MailerLite (account 2375797) ---
# Get it: MailerLite dashboard -> Integrations -> API -> generate/copy token.
# Unlocks: calmoak-email autonomous newsletter + welcome sends.
MAILERLITE_API_KEY=

# --- #6 Affiliate: Awin (diversify beyond Amazon) ---
# Get it: awin.com publisher dashboard -> your account. Plus join merchant programs (Etsy, Quince).
# Unlocks: higher-commission affiliate links (Etsy/fashion) the agents can generate.
AWIN_PUBLISHER_ID=

# --- Live Google Search Console (free, no Ahrefs) — see GSC-SETUP.md ---
# Paste the WHOLE service-account JSON as one line.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Your GSC property: sc-domain:calmandoak.com  OR  https://calmandoak.com/
GSC_SITE_URL=sc-domain:calmandoak.com
# GA4 analytics — SAME service account (grant it Viewer on the GA4 property).
# Numeric Property ID: GA4 Admin -> Property Settings -> Property ID.
GA4_PROPERTY_ID=

# --- #7 True 24/7: headless/cloud agent runs ---
# Get it: console.anthropic.com -> API keys.
# Unlocks: running the agent fleet in the cloud (GitHub Action / runner) even when your computer is off.
ANTHROPIC_API_KEY=
