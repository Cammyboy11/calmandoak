# Files Cloudflare should NOT publish to the live site.
# Same idea as .gitignore but for the deployed bundle.

# Git internals (the cause of the deploy failure)
.git
.git/**
.gitignore
.gitattributes

# Node / build artifacts
node_modules
node_modules/**
.cache
.cache/**
.wrangler
.wrangler/**
wrangler.jsonc
wrangler.toml

# Documentation that shouldn't be public-facing
README.md
DEPLOY-NOW.md
GITHUB-PUSH-WALKTHROUGH.md
3-PLACEHOLDERS-HOW-TO.md
OPTIMIZATION-NOTES.md

# Uncropped master pin copies — kept in repo as the 1:1 source of truth
# but never deployed to the live site. Only the cropped versions in
# /assets/img/products-cropped/ ship.
assets/img/products
assets/img/products/**

# Master pin folder (also gitignored, but belt-and-braces)
final pins
final pins/**

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
~$*

# This file itself
.assetsignore
